# Hardhat / Smart Contract Layer
# Copy to .env and fill in your values

# Private key of the account used to deploy contracts (no 0x prefix for some tools)
DEPLOYER_PRIVATE_KEY=your_deployer_private_key_here

# Polygon Amoy testnet RPC (default below is public — replace with your Alchemy/Infura URL for reliability)
POLYGON_AMOY_RPC_URL=https://rpc-amoy.polygon.technology
