# AI Crime Detection Service — copy to .env and fill in your values

AI_SERVICE_PORT=8000
DEBUG=true

# Video source: 0 = default webcam, RTSP URL, or local file path
VIDEO_SOURCE=0
CAMERA_ID=CAM-001

# Detection tuning
DETECTION_THRESHOLD=0.6
ANALYSIS_FPS=5
BUFFER_DURATION_SECONDS=5
POST_INCIDENT_DURATION_SECONDS=5

# Device for PyTorch inference: 'cpu' or 'cuda'
MODEL_DEVICE=cpu

# URL of the running backend API
BACKEND_URL=http://localhost:5000
BACKEND_TIMEOUT_SECONDS=30

# Local storage limits
MAX_RECORDINGS_GB=10
RETENTION_DAYS=7
