# Backend API — copy to .env and fill in your values

PORT=5000
DATABASE_PATH=./database/evidence.db

# Strong random secret used to sign JWT tokens — change before deploying
JWT_SECRET=change-this-to-a-long-random-string

# RPC endpoint for the blockchain node
# Local Hardhat sandbox (default):
HARDHAT_NETWORK_URL=http://127.0.0.1:8545
# Polygon Amoy testnet example:
# HARDHAT_NETWORK_URL=https://rpc-amoy.polygon.technology

# Address of the deployed EvidenceLog contract
CONTRACT_ADDRESS=0xYourContractAddressHere

# Private key of the wallet that submits transactions (with 0x prefix)
# For local Hardhat use any of the pre-funded test accounts
PRIVATE_KEY=0xYourPrivateKeyHere
